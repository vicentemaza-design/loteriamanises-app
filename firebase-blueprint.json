{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information including balance and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "balance": { "type": "number", "description": "Current wallet balance in Euros" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "balance"]
    },
    "Ticket": {
      "title": "Lottery Ticket",
      "description": "A lottery ticket purchased by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ticket ID" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "gameId": { "type": "string", "description": "ID of the lottery game" },
        "gameType": { "type": "string", "enum": ["primitiva", "bonoloto", "euromillones", "gordo", "loteria-nacional", "eurodreams"] },
        "numbers": { "type": "array", "items": { "type": "number" }, "description": "Selected numbers" },
        "stars": { "type": "array", "items": { "type": "number" }, "description": "Selected stars (if applicable)" },
        "drawDate": { "type": "string", "format": "date", "description": "Date of the draw" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "prize": { "type": "number", "description": "Prize amount if won" },
        "price": { "type": "number", "description": "Cost of the ticket" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Purchase timestamp" }
      },
      "required": ["userId", "gameId", "numbers", "drawDate", "status", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profiles"
    },
    "/tickets/{ticketId}": {
      "schema": { "$ref": "Ticket" },
      "description": "All lottery tickets"
    }
  }
}
