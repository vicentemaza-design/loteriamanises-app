# ── Data provider ────────────────────────────────────────────────────────────
# Controls which adapter the app uses. Copy this file to .env.local and set
# the values for your environment.
#
# Options:
#   mock     — All data is local/in-memory. No external services needed.
#              Use this for UI development and demos.
#   firebase — Reads/writes Firestore. Requires Firebase credentials below.
#   http     — Calls the REST API. Requires VITE_API_BASE_URL below.
#              (HTTP adapter is not yet implemented — see src/services/api/adapters/http/)
VITE_API_PROVIDER=mock

# ── REST API (required when VITE_API_PROVIDER=http) ──────────────────────────
VITE_API_BASE_URL=https://api.loteriamanises.com/v1

# ── Firebase (required when VITE_API_PROVIDER=firebase) ──────────────────────
# Obtain these values from the Firebase console → Project settings → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
